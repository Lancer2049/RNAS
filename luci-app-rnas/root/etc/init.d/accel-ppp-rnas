#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

NAME=accel-ppp
DESC="ACCEL-PPP Daemon"

CONF_FILE="/etc/accel-ppp.conf"
PID_FILE="/var/run/accel-ppp/accel-ppp.pid"

uci_get_by_name() {
    local type="$1"
    local name="$2"
    local option="$3"
    local default="$4"
    uci get "${type}.${name}.${option}" 2>/dev/null || echo "$default"
}

start_service() {
    local enabled=$(uci_get_by_name rnas config enabled 0)
    [ "$enabled" = "1" ] || return 0

    config_load rnas
    
    local protocol=$(uci get rnas.config.protocol 2>/dev/null || echo "pppoe")
    local server=$(uci get rnas.radius.server 2>/dev/null || echo "192.168.1.1")
    local secret=$(uci get rnas.radius.secret 2>/dev/null || echo "testing123")
    local auth_port=$(uci get rnas.radius.auth_port 2>/dev/null || echo "1812")
    local acct_port=$(uci get rnas.radius.acct_port 2>/dev/null || echo "1813")
    local coa_port=$(uci get rnas.radius.coa_port 2>/dev/null || echo "3799")
    local thread_count=$(uci get rnas.config.thread_count 2>/dev/null || echo "4")
    
    mkdir -p /var/log/accel-ppp
    mkdir -p /var/run/accel-ppp

    procd_open_instance
    procd_set_param command /usr/sbin/accel-pppd
    procd_append_param command -c "$CONF_FILE"
    procd_append_param command -d
    procd_set_param pidfile "$PID_FILE"
    procd_set_param respawn
    procd_close_instance
}

reload_service() {
    restart
}

stop_service() {
    if [ -f "$PID_FILE" ]; then
        kill $(cat "$PID_FILE") 2>/dev/null
        rm -f "$PID_FILE"
    fi
}

status() {
    if [ -f "$PID_FILE" ] && kill -0 $(cat "$PID_FILE") 2>/dev/null; then
        echo "accel-ppp is running"
        return 0
    else
        echo "accel-ppp is not running"
        return 1
    fi
}
