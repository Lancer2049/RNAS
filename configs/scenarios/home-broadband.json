{
  "name": "Home Broadband",
  "description": "Standard home PPPoE connection with per-user QoS",
  "config": {
    "access.d.core": {"pppoe": "yes", "ipoe": "no", "l2tp": "no", "pptp": "no", "sstp": "no"},
    "access.d.ppp": {"mtu": "1492", "mru": "1492"},
    "access.d.radius": {"nas_identifier": "rnas-home"},
    "qos.global": {"enabled": "yes", "algorithm": "cake", "interface": "ens33"},
    "qos.per_user": {"enabled": "yes", "default_rate": "20mbit", "default_ceil": "50mbit"},
    "vpn.d.ipsec": {"enabled": "no"},
    "vpn.d.wireguard": {"enabled": "no"},
    "vpn.d.openvpn": {"enabled": "no"}
  }
}
