#!/bin/bash
# accel-ppp-uci - UCI configuration translator for accel-ppp
#
# Translates OpenWrt UCI configuration (/etc/config/accel-ppp) to
# accel-ppp native config format. This is the core of the "no third-party
# appearance" integration â€” all management goes through UCI.
#
# Usage:
#   accel-ppp-ucigenerate    # Generate accel-ppp.conf to stdout
#   accel-ppp-ucivalidate    # Validate current UCI config
#   accel-ppp-ucishow        # Show effective accel-ppp parameters

set -e

UCI_PACKAGE="rnas"
log_info() {
	echo "[INFO] $1" >&2
}

log_error() {
	echo "[ERROR] $1" >&2
}

# Read a UCI option with fallback
uci_get() {
	local section="$1"
	local option="$2"
	local default="$3"
	local val

	val=$(uci -q get "${UCI_PACKAGE}.${section}.${option}" 2>/dev/null)
	echo "${val:-$default}"
}

# Generate accel-ppp.conf from UCI
cmd_generate() {
	local enabled

	enabled=$(uci_get global enabled 1)
	[ "$enabled" != "0" ] || {
		log_error "accel-ppp is disabled"
		return 1
	}

	cat <<- 'SECTION_HEADER'
		# accel-ppp configuration
		# Auto-generated from UCI (/etc/config/accel-ppp)
		# Do NOT edit this file directly â€” use 'uci' commands instead
		#

	SECTION_HEADER

	# [core]
	local thread_count
	thread_count=$(uci_get global thread_count 4)
	cat <<- CORE
		[core]
		thread-count=${thread_count}
		pid-file=/var/run/accel-ppp.pid

	CORE

	# [ppp]
	local min_mtu mtu mru lcp_echo_interval lcp_echo_failure
	min_mtu=$(uci_get ppp min_mtu 1280)
	mtu=$(uci_get ppp mtu 1492)
	mru=$(uci_get ppp mru 1492)
	lcp_echo_interval=$(uci_get ppp lcp_echo_interval 30)
	lcp_echo_failure=$(uci_get ppp lcp_echo_failure 3)
	cat <<- PPP
		[ppp]
		min-mtu=${min_mtu}
		mtu=${mtu}
		mru=${mru}
		lcp-echo-interval=${lcp_echo_interval}
		lcp-echo-failure=${lcp_echo_failure}
		acf=$(uci_get ppp acf 0)
		pcf=$(uci_get ppp pcf 0)

	PPP

	# [pppoe] - enabled if interface is set
	local pppoe_iface
	pppoe_iface=$(uci_get pppoe interface "")
	if [ -n "$pppoe_iface" ]; then
		cat <<- PPPOE
			[pppoe]
			interface=${pppoe_iface}
			service-name=$(uci_get pppoe service_name "")
			AC-name=$(uci_get pppoe ac_name RNAS-OpenWrt)
			verbose=$(uci_get pppoe verbose 1)

		PPPOE
	fi

	# [ipoe] - enabled if enabled=1
	if [ "$(uci_get ipoe enabled 0)" = "1" ]; then
		local ipoe_iface
		ipoe_iface=$(uci_get ipoe interface "")
		cat <<- IPOE
			[ipoe]
			verbose=$(uci_get ipoe verbose 1)
		IPOE
		[ -n "$ipoe_iface" ] && echo "interface=${ipoe_iface}"
		echo ""
	fi

	# [l2tp] - enabled if enabled=1
	if [ "$(uci_get l2tp enabled 0)" = "1" ]; then
		cat <<- L2TP
			[l2tp]
			verbose=$(uci_get l2tp verbose 1)
			port=$(uci_get l2tp port 1701)

		L2TP
	fi

	# [pptp] - enabled if enabled=1
	if [ "$(uci_get pptp enabled 0)" = "1" ]; then
		cat <<- PPTP
			[pptp]
			verbose=$(uci_get pptp verbose 1)

		PPTP
	fi

	# [sstp] - enabled if enabled=1
	if [ "$(uci_get sstp enabled 0)" = "1" ]; then
		cat <<- SSTP
			[sstp]
			verbose=$(uci_get sstp verbose 1)
			port=$(uci_get sstp port 443)

		SSTP
	fi

	# [auth]
	local radius_server
	radius_server=$(uci_get radius auth_server "")
	if [ -n "$radius_server" ]; then
		local msg_auth
		msg_auth=$(uci_get radius message_authenticator 1)
		cat <<- AUTH
			[auth]
			auth=Radius
			radius-auth-port=$(uci_get radius auth_port 1812)
			radius-acct-port=$(uci_get radius acct_port 1813)
			radius-secret=$(uci_get radius secret testing123)
			radius-timeout=$(uci_get radius timeout 30)
			radius-retries=$(uci_get radius retries 3)

		AUTH
		# require-message-authenticator (0=disabled, 1=enabled)
		[ "$msg_auth" = "1" ] && echo "require-message-authenticator=yes" || echo "require-message-authenticator=no"
		echo ""
	else
		cat <<- AUTH_LOCAL
			[auth]
			auth=local
			auth-chap=yes
			auth-pap=yes
			auth-mschap-v1=yes
			auth-mschap-v2=yes

		AUTH_LOCAL
	fi

	# [acct]
	if [ -n "$radius_server" ]; then
		local acct_on
		acct_on=$(uci_get radius acct_on 0)
		cat <<- ACCT
			[acct]
			interim-interval=$(uci_get radius interim_interval 300)
			interim-jitter=$(uci_get radius interim_jitter 100)

		ACCT
		# Accounting-On packet on startup
		[ "$acct_on" = "1" ] && echo "acct-on=yes" && echo ""
	fi

	# [radius] - RADIUS client identification
	if [ -n "$radius_server" ]; then
		local nas_id nas_ip gw_ip radius_verbose
		nas_id=$(uci_get radius nas_identifier "")
		nas_ip=$(uci_get radius nas_ip_address "")
		gw_ip=$(uci_get radius gw_ip_address "")
		radius_verbose=$(uci_get radius verbose 0)
		if [ -n "$nas_id" ] || [ -n "$nas_ip" ]; then
			cat <<- RADIUS_SECTION
				[radius]
			RADIUS_SECTION
			[ -n "$nas_id" ] && echo "nas-identifier=${nas_id}"
			[ -n "$nas_ip" ] && echo "nas-ip-address=${nas_ip}"
			[ -n "$gw_ip" ] && echo "gw-ip-address=${gw_ip}"
			[ "$radius_verbose" = "1" ] && echo "verbose=1"
			echo ""
		fi
	fi

	# [coa]
	if [ "$(uci_get coa enabled 0)" = "1" ]; then
		cat <<- COA
			[coa]
			enable-coa=yes
			radius-coa-port=$(uci_get coa port 3799)
			radius-coa-secret=$(uci_get coa secret "$(uci_get radius secret testing123)")

		COA
	fi

	# [ip-pool]
	local gateway pool
	gateway=$(uci_get ip_pool gateway "")
	pool=$(uci_get ip_pool pool "")
	if [ -n "$gateway" ] && [ -n "$pool" ]; then
		cat <<- IPPOOL
			[ip-pool]
			gw-ip-address=${gateway}
			pool=${pool},$(uci_get ip_pool netmask 255.255.255.0)

		IPPOOL
	fi

	# [dns]
	cat <<- DNS
		[dns]
		dns1=$(uci_get dns dns1 8.8.8.8)
		dns2=$(uci_get dns dns2 8.8.4.4)

	DNS

	# [ppp-dns]
	cat <<- PPPDNS
		[ppp-dns]
		accept-peer-dns=yes

	PPPDNS

	# [log]
	cat <<- LOG
		[log]
		log-verbosity=$(uci_get global log_level 3)
		log-file=$(uci_get global log_file /var/log/accel-ppp.log)
	LOG
	if [ "$(uci_get global log_syslog 0)" = "1" ]; then
		echo "log-emergency=syslog"
		echo "log-facility=daemon"
	fi

	# [connlimit]
	local max_sess
	max_sess=$(uci_get limit max_sessions 10000)
	cat <<- CONNLIMIT
		[connlimit]
		limit=${max_sess}
		burst=$(uci_get limit max_sessions_per_vlan 1000)
		timeout=60

	CONNLIMIT

	# [ppp-mppe]
	if [ "$(uci_get mppe enabled 0)" = "1" ]; then
		cat <<- MPPE
			[ppp-mppe]
			$( [ "$(uci_get mppe require 0)" = "1" ] && echo "require-mppe" || echo "optional" )
			$( [ "$(uci_get mppe compression 1)" = "1" ] && echo "prefer-compression=yes" || echo "no-compression" )

		MPPE
	fi

	# [ppp-static-ip]
	cat <<- STATICIP
		[ppp-static-ip]

	STATICIP

	# [shell]
	cat <<- SHELL
		[shell]
		enable-chap=yes
		enable-pap=yes
		enable-mschap-v1=yes
		enable-mschap-v2=yes
		enable-radius=yes
		max-logins=$(uci_get limit concurrent_limit 1)

	SHELL
}

# Validate UCI configuration
cmd_validate() {
	local errors=0

	# Check required sections
	for section in global ppp pppoe ipoe radius; do
		if ! uci -q get "${UCI_PACKAGE}.${section}" > /dev/null 2>&1; then
			log_error "Missing required section: ${section}"
			errors=$((errors + 1))
		fi
	done

	# Validate RADIUS config
	local auth_server
	auth_server=$(uci_get radius auth_server "")
	if [ -n "$auth_server" ]; then
		local secret
		secret=$(uci_get radius secret "")
		if [ -z "$secret" ]; then
			log_error "RADIUS secret is empty"
			errors=$((errors + 1))
		fi
	fi

	# Validate PPPoE interface
	local pppoe_iface
	pppoe_iface=$(uci_get pppoe interface "")
	if [ -z "$pppoe_iface" ]; then
		log_error "PPPoE interface not configured"
		errors=$((errors + 1))
	fi

	if [ "$errors" -gt 0 ]; then
		log_error "Validation failed with ${errors} error(s)"
		return 1
	fi

	log_info "UCI configuration is valid"
	return 0
}

# Show effective parameters
cmd_show() {
	echo "=== accel-ppp UCI Configuration ==="
	echo ""
	uci show "${UCI_PACKAGE}" 2>/dev/null || {
		log_error "UCI package '${UCI_PACKAGE}' not found"
		return 1
	}
}

case "${1:-generate}" in
	generate)
		cmd_generate
		;;
	validate)
		cmd_validate
		;;
	show)
		cmd_show
		;;
	*)
		echo "Usage: $0 {generate|validate|show}"
		echo ""
		echo "  generate  Generate accel-ppp.conf from UCI (stdout)"
		echo "  validate  Validate current UCI configuration"
		echo "  show      Show current UCI configuration"
		exit 1
		;;
esac
