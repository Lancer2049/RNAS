#!/bin/sh /etc/rc.common
#
# Init script for accel-ppp (RNAS-OpenWrt)
# procd-based service management — fully integrated into OpenWrt
#
# This script reads UCI configuration from /etc/config/accel-ppp and
# translates it to accel-ppp native config at startup, making accel-ppp
# appear as a fully native OpenWrt service.
#

USE_PROCD=1

START=90
STOP=10

PROG=/usr/sbin/accel-pppd
CONFIG_DIR=/var/etc/accel-ppp
CONFIG_FILE=${CONFIG_DIR}/accel-ppp.conf
PID_FILE=/var/run/accel-ppp.pid
UCI_BIN=/usr/sbin/accel-ppp-uci

validate_uci_section() {
	local section="$1"
	local type="$2"
	config_get enabled "$section" enabled 1
	[ "$enabled" != "0" ] || return 1
	return 0
}

generate_config() {
	# Ensure config directory exists
	mkdir -p "$CONFIG_DIR"

	# Delegate config generation to the UCI translation utility
	${UCI_BIN} generate > "$CONFIG_FILE" 2>/dev/null
	return $?
}

start_service() {
	# Check if accel-ppp is globally enabled
	local enabled
	config_load rnas
	config_get enabled global enabled 1
	[ "$enabled" != "0" ] || {
		echo "accel-ppp is disabled in UCI config"
		return 1
	}

	# Generate config from UCI
	generate_config || {
		echo "Failed to generate accel-ppp configuration from UCI"
		return 1
	}

	# Start with procd
	procd_open_instance
	procd_set_param command "$PROG" -c "$CONFIG_FILE"
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param pidfile "$PID_FILE"
	procd_close_instance
}

stop_service() {
	# Kill accel-pppd gracefully
	service_stop /usr/sbin/accel-pppd
}

reload_service() {
	# Regenerate config and send SIGHUP for reload
	generate_config
	kill -HUP $(cat "$PID_FILE" 2>/dev/null) 2>/dev/null || start_service
}

service_triggers() {
	procd_add_reload_trigger rnas
}

boot() {
	ubus call service register '{"name":"accel-ppp","instances":{"main":{"command":"/etc/init.d/accel-ppp","data":{}}}}' 2>/dev/null || true
	start
}
